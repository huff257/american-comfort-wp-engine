{
  "apiVersion": 3,
  "name": "building-blocks-theme/bb-video",
  "title": "Hero Video",
  "category": "media",
  "icon": "media",
  "description": "Performance-optimized hero video block with responsive poster image and optional mobile video fallback.",
  "supports": {
    "html": false,
    "align": [
      "full"
    ],
    "anchor": true
  },
  "attributes": {
    "videoUrl": {
      "type": "string",
      "default": ""
    },
    "videoId": {
      "type": "number"
    },
    "posterId": {
      "type": "number"
    },
    "posterUrl": {
      "type": "string",
      "default": ""
    },
    "posterAlt": {
      "type": "string",
      "default": ""
    },
    "posterWidth": {
      "type": "number"
    },
    "posterHeight": {
      "type": "number"
    },
    "posterSrcSet": {
      "type": "string",
      "default": ""
    },
    "posterSizes": {
      "type": "string",
      "default": "(max-width: 768px) 100vw, 100vw"
    },
    "useMobileFallback": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "file:./build/index.js"
}